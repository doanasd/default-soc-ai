GROQ_API_KEY=

# Paths
LOG_INPUT_PATH=/var/ossec/logs/log_dedup.json
ALERT_OUTPUT_PATH=./data/alerts.jsonl
CONTEXT_DIR=./context

# LLM configuration
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SECONDS=15
GROQ_MAX_RETRIES=3

BATCH_WINDOW_SECONDS=300
BATCH_IDLE_TIMEOUT_SECONDS=120

# Service behavior
POLL_INTERVAL_SECONDS=1.0
ALERT_SUPPRESSION_TTL_SECONDS=300
MAX_CONTEXT_CHARS=20000

# Logging
LOG_LEVEL=INFO


TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=10


NO_ALERT_SUMMARY_INTERVAL_SECONDS=3600

MODEL_USAGE_REPORT_PATH=./data/model_usage_costs.txt
GROQ_INPUT_COST_PER_MILLION=0.15
GROQ_CACHED_INPUT_COST_PER_MILLION=0.075
GROQ_OUTPUT_COST_PER_MILLION=0.60

# ── Investigation Queue (Bridge to Threat Hunter) ─────────────────────────
INVESTIGATION_QUEUE_PATH=../threat_hunter/data/pending_investigations.jsonl
