# ── MCP & OpenSearch ──────────────────────────────────────────────────────────
MCP_SERVER_URL=http://10.10.10.20:9900/mcp/
MCP_TOOL_NAME=SearchIndexTool
OPENSEARCH_INDEX_PATTERN=soc-logs-*

# ── Schedule ──────────────────────────────────────────────────────────────────
HUNT_INTERVAL_SECONDS=21600
HUNT_LOOKBACK_HOURS=24

# ── LLM (Groq) ───────────────────────────────────────────────────────────────
HUNT_GROQ_API_KEY=
HUNT_GROQ_MODEL=llama3-70b-versatile
HUNT_GROQ_MAX_TOKENS=4096
HUNT_GROQ_TIMEOUT_SECONDS=60

# ── Hunt Agent Limits ─────────────────────────────────────────────────────────
MAX_TOOL_CALLS_PER_HYPOTHESIS=3
MAX_LOG_RESULTS_PER_QUERY=100

# ── Output ────────────────────────────────────────────────────────────────────
HUNT_FINDINGS_OUTPUT_PATH=./data/hunt_findings.jsonl
HUNT_BASELINE_PATH=./data/baseline.json

# ── Telegram ──────────────────────────────────────────────────────────────────
HUNT_TELEGRAM_BOT_TOKEN=
HUNT_TELEGRAM_CHAT_ID=-
HUNT_TELEGRAM_TIMEOUT_SECONDS=10

# ── Investigation Queue (Bridge from AI Alert) ───────────────────────────────
INVESTIGATION_QUEUE_PATH=./data/pending_investigations.jsonl
INVESTIGATION_QUEUE_POLL_SECONDS=10

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
